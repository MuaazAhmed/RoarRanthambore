        "url": {"raw": "http://localhost:8080/bookings/1", "protocol": "http", "host": ["localhost"], "port": ["8080"], "path": ["bookings", "1"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"date\": \"2026-03-20\",\n  \"zone\": \"Zone 2\"\n}"
        }
      }
    },
    {
      "name": "Delete Booking",
      "request": {
        "method": "DELETE",
        "url": {"raw": "http://localhost:8080/bookings/1", "protocol": "http", "host": ["localhost"], "port": ["8080"], "path": ["bookings", "1"]}
      }
    },
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:8080/admin/login", "protocol": "http", "host": ["localhost"], "port": ["8080"], "path": ["admin", "login"]},
        "body": {
